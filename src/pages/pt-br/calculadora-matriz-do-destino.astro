---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Calculator from '../../components/Calculator.astro';

const title = 'Calculadora Matriz do Destino — Como ler o que seus números significam';
const description = 'Use a calculadora Matriz do Destino gratuita e entenda o que cada posição do seu mapa revela. Guia completo de interpretação: posição A (dia), B (mês), C (ano), D (síntese), E (centro) e os quatro pontos médios.';
const canonicalUrl = 'https://matrixdestiny.co/pt-br/calculadora-matriz-do-destino';

const hreflang = [
  { lang: 'pt-BR', url: 'https://matrixdestiny.co/pt-br/calculadora-matriz-do-destino' },
  { lang: 'uk', url: 'https://matrixdestiny.co/uk/kalkulator-matrytsia-doli' },
];

const relationships = {
  isA: 'hub de calculadora e interpretação — página central que conecta o cálculo ao significado de cada posição do mapa',
  usedFor: [
    'calcular a Matriz do Destino gratuitamente pela data de nascimento',
    'entender o que cada uma das 9 posições do mapa representa',
    'identificar qual arcano está em cada posição e acessar sua interpretação',
    'comparar padrões entre posições e identificar temas centrais no mapa',
    'como ponto de entrada para leitura do mapa de outras pessoas',
  ],
  worksWith: [1, 6, 10, 13, 21, 22],
  conflictsWith: [12, 18],
  causes: [
    'geração do mapa individual — ponto de partida concreto para interpretação',
    'acesso direto às páginas de cada arcano para aprofundamento de cada posição',
    'clareza sobre o que o sistema calcula e o que ele não calcula',
  ],
};

const faq = [
  {
    q: 'A calculadora usa o método correto de Natalia Ladini?',
    a: 'Sim. A lógica de cálculo implementada segue o método padrão: dia reduzido por soma de dígitos se maior que 22, mês usado diretamente (1–12), ano com soma dos quatro dígitos reduzida se necessário. As posições D (síntese de A+B+C) e E (síntese de A+B+C+D) são calculadas com a mesma função de redução. Os quatro pontos médios (AB, BC, CD, DA) usam a soma de cada par de posições adjacentes.',
  },
  {
    q: 'O que significa quando o mesmo arcano aparece em mais de uma posição?',
    a: 'Quando um arcano se repete, ele representa um tema central no mapa — algo que opera de forma consistente em diferentes dimensões da pessoa. Não é necessariamente bom ou ruim; indica que o padrão desse arcano é uma força organizadora forte. Por exemplo, o Arcano 1 (O Mago) nas posições A e E sugere que a agência e a capacidade de iniciativa são tanto o motor primário quanto o núcleo de integração — o que pode manifestar como clareza de propósito muito forte, ou como paralisia quando a intenção não está clara.',
  },
  {
    q: 'Posso calcular a Matriz de outra pessoa pela calculadora?',
    a: 'Sim, a calculadora aceita qualquer data de nascimento válida. Para calcular o mapa de outra pessoa, basta inserir os dados de nascimento dela. A interpretação do mapa de terceiros requer atenção ao contexto de vida dessa pessoa — o mapa descreve tendências, não realidades fixas, e a mesma posição pode estar operando de formas muito diferentes dependendo da história individual.',
  },
  {
    q: 'O que é a posição E (centro) e por que ela é importante?',
    a: 'A posição E é calculada somando as quatro posições anteriores (A+B+C+D) e reduzindo. Representa o núcleo de integração do mapa — o padrão que emerge quando todos os outros estão operando em conjunto. É frequentemente o arcano mais difícil de acessar conscientemente, porque depende da integração das outras quatro posições. Quando o E está ativado, a pessoa experimenta uma sensação de coerência interna que raramente está presente no cotidiano.',
  },
  {
    q: 'Qual é a diferença entre as posições dos cantos e os pontos médios?',
    a: 'As quatro posições dos cantos (A, B, C, D) representam funções psicológicas distintas e primárias — são os inputs principais do mapa. Os quatro pontos médios (AB, BC, CD, DA) representam a qualidade da transição entre essas funções — como a energia passa de um polo ao outro. Um ponto médio com um arcano de alta tensão (como o 15 ou o 16) indica que a passagem entre essas duas funções é frequentemente conflitada.',
  },
  {
    q: 'A data de nascimento usada deve ser pelo calendário gregoriano?',
    a: 'Sim. O método da Matriz do Destino usa o calendário gregoriano — o padrão ocidental de dia, mês e ano. Se você nasceu em uma cultura que usa outro calendário como padrão, converta para o gregoriano antes de calcular.',
  },
  {
    q: 'Como interpretar arcanos que conflitam entre si em posições adjacentes?',
    a: 'Arcanos adjacentes no mapa que têm relação de conflito (por exemplo, 15 e 10, ou 12 e 8) criam uma tensão específica entre as funções que eles representam. Essa tensão não é um "problema" fixo — é uma área que frequentemente gera atrito e que, quando trabalhada conscientemente, se torna uma fonte de desenvolvimento. O ponto médio entre as duas posições conflitantes revela qual tipo de energia ajuda a mediar essa tensão.',
  },
];

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  inLanguage: 'pt-BR',
  publisher: { '@type': 'Organization', name: 'Matrix Destiny', url: 'https://matrixdestiny.co' },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://matrixdestiny.co/pt-br/' },
    { '@type': 'ListItem', position: 2, name: 'Calculadora Matriz do Destino', item: canonicalUrl },
  ],
});
---

<Base title={title} description={description} lang="pt-BR" hreflang={hreflang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <Header lang="pt-br" />

  <main class="max-w-3xl mx-auto px-6 py-12">

    <nav aria-label="breadcrumb" class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/pt-br/" class="hover:text-purple-600 transition-colors">Início</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-800 font-medium">Calculadora Matriz do Destino</span>
    </nav>

    <header class="mb-10">
      <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
        Hub Calculadora
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 mb-4 leading-tight">
        Calculadora Matriz do Destino — Como ler o que seus números significam
      </h1>
      <p class="text-lg text-gray-500 leading-relaxed">{description}</p>
    </header>

    <!-- Calculator embedded -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 mb-14">
      <Calculator lang="pt-br" />
    </div>

    <article class="mb-14 text-gray-700 leading-relaxed space-y-5
      [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-gray-900 [&_h2]:mt-10 [&_h2]:mb-3
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-gray-900 [&_h3]:mt-6 [&_h3]:mb-2
      [&_p]:mb-0
      [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1
      [&_strong]:font-semibold [&_strong]:text-gray-900">

      <h2>Como usar a calculadora</h2>

      <p>Insira seu dia de nascimento (1–31), mês (1–12) e ano completo com quatro dígitos no campo correspondente. A calculadora aplica automaticamente a lógica de redução do método: dia e ano são reduzidos se gerarem valores acima de 22, mês é usado diretamente. O resultado aparece como um diamante com nove posições, cada uma numerada e vinculada à página de interpretação do arcano correspondente.</p>

      <p>O cálculo é instantâneo e não requer cadastro. Se quiser guardar seu resultado, anote os valores de cada posição ou tire um screenshot — a calculadora não armazena dados.</p>

      <h2>O que cada posição do mapa representa</h2>

      <p>As nove posições do mapa não têm hierarquia fixa — cada uma descreve um aspecto diferente de como a pessoa funciona. Entender o que cada posição mede é o pré-requisito para uma leitura útil.</p>

      <h3>Posição A — Dia de nascimento: o motor da ação</h3>
      <p>O arcano na posição A representa como a pessoa inicia — o padrão que ativa quando ela age de forma mais instintiva, sem planejamento prévio. É a energia "de saída" do mapa. O <a href="/pt-br/arcana/1" class="text-purple-600 hover:underline">Arcano 1 (O Mago)</a> na posição A indica iniciativa direta e intenção forte; o <a href="/pt-br/arcana/12" class="text-purple-600 hover:underline">Arcano 12 (O Enforcado)</a> indica um padrão de espera e suspensão antes de qualquer movimento.</p>

      <h3>Posição B — Mês de nascimento: o campo social</h3>
      <p>A posição B descreve como a pessoa opera em contextos relacionais e sociais — o que ela projeta para o ambiente, como é percebida por outros, e os padrões que ativam em grupo ou em situações de visibilidade. O <a href="/pt-br/arcana/19" class="text-purple-600 hover:underline">Arcano 19 (O Sol)</a> na posição B indica presença natural e capacidade de energizar o ambiente; o <a href="/pt-br/arcana/18" class="text-purple-600 hover:underline">Arcano 18 (A Lua)</a> indica que o campo social ativa projeções e ansiedade antecipatória.</p>

      <h3>Posição C — Ano de nascimento: os condicionamentos profundos</h3>
      <p>O arcano em C representa padrões formados cedo — condicionamentos que operam de forma mais automática e menos consciente. É a posição mais "antiga" do mapa, no sentido de que seus padrões têm raízes mais profundas e são mais lentos para transformar. O <a href="/pt-br/arcana/4" class="text-purple-600 hover:underline">Arcano 4 (O Imperador)</a> em C pode indicar um condicionamento de necessidade de controle e estrutura adquirido muito cedo; o <a href="/pt-br/arcana/6" class="text-purple-600 hover:underline">Arcano 6 (Os Amantes)</a> indica um condicionamento em torno de escolha, comprometimento e dilema.</p>

      <h3>Posição D — Síntese: o vetor de missão</h3>
      <p>A posição D é calculada somando A+B+C e reduzindo. Não é um input direto da data — é derivado. Representa a direção de desenvolvimento que emerge da interação entre ação, campo social e condicionamentos. É frequentemente chamada de "missão" no sistema, mas com precisão psicológica: é o padrão que a pessoa tende a desenvolver quando as três posições primárias estão funcionando de forma integrada.</p>

      <h3>Posição E — Centro: o núcleo de integração</h3>
      <p>O arcano central é calculado somando todas as quatro posições anteriores (A+B+C+D). Representa o estado de coerência interna — o que emerge quando todas as dimensões do mapa estão alinhadas. É raramente acessível de forma consistente no cotidiano, mas aparece em momentos de alto funcionamento. O <a href="/pt-br/arcana/21" class="text-purple-600 hover:underline">Arcano 21 (O Mundo)</a> no centro sugere que o estado de integração profunda tem qualidade de completude e síntese; o <a href="/pt-br/arcana/16" class="text-purple-600 hover:underline">Arcano 16 (A Torre)</a> no centro indica que o acesso ao estado de integração frequentemente passa por rupturas e colapsos de estruturas falsas.</p>

      <h3>Os quatro pontos médios: as transições</h3>
      <p>As posições AB, BC, CD e DA representam a qualidade da transição entre as posições que as flanqueiam. Um arcano de alta tensão nesses pontos (como o <a href="/pt-br/arcana/15" class="text-purple-600 hover:underline">Arcano 15 (O Diabo)</a> ou o <a href="/pt-br/arcana/13" class="text-purple-600 hover:underline">Arcano 13 (A Morte)</a>) indica que a passagem de energia entre essas duas funções frequentemente encontra atrito — o que pode ser vivenciado como conflito entre ação e relacionamento, ou entre condicionamentos e missão.</p>

      <h2>Como ler o resultado: da posição ao padrão</h2>

      <p>Um erro comum na leitura da Matriz é interpretar cada posição isoladamente, como se fossem indicadores independentes. O mapa funciona como sistema: as posições se influenciam. A leitura útil passa por identificar temas transversais — arcanos que se repetem, tensões específicas entre posições adjacentes, e a distância entre o arcano em A (como a pessoa age) e o arcano em E (como ela poderia agir se integrada).</p>

      <p>Comece pelas quatro posições dos cantos. Identifique se há repetições — o mesmo arcano em A e D, por exemplo, sugere que o padrão de ação e o vetor de missão se alinham de forma forte. Depois, observe os pontos médios: qual é a qualidade do eixo A-B (ação e campo social)? Há tensão ali? Finalmente, o E — qual é a distância entre como você funciona agora (A, B, C) e o estado de integração que o E representa?</p>

      <h2>O que acontece depois de calcular</h2>

      <p>Calcular é apenas o primeiro passo. O valor real do mapa está em aprofundar cada posição: entender em qual polo cada arcano está operando — ativo ou bloqueado — e identificar qual dos padrões descritos ressoa com sua experiência atual. Use os links no diamante para acessar a interpretação completa de cada arcano na sua posição específica.</p>

      <p>Se quiser ir além da leitura individual, a Matriz também é usada para análise de <a href="/pt-br/compatibilidade-matriz-do-destino" class="text-purple-600 hover:underline">compatibilidade entre dois mapas</a> — comparando posições equivalentes e identificando onde há sinergia natural e onde há tensão estrutural.</p>

      <p>Para entender o método desde o princípio, leia <a href="/pt-br/o-que-e-matriz-do-destino" class="text-purple-600 hover:underline">o que é a Matriz do Destino</a> antes de interpretar seu resultado.</p>
    </article>

    <!-- Entity Relationship Table -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Relações de Entidade</h2>
      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="px-5 py-3 font-mono text-xs font-semibold text-purple-600 bg-gray-50 w-36 align-top pt-4">É UM(A)</td>
              <td class="px-5 py-3 text-gray-700">{relationships.isA}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-5 py-3 font-mono text-xs font-semibold text-purple-600 bg-gray-50 align-top pt-4">USADO PARA</td>
              <td class="px-5 py-3 text-gray-700">
                <ul class="space-y-1 list-disc list-inside">
                  {relationships.usedFor.map((item) => <li>{item}</li>)}
                </ul>
              </td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-5 py-3 font-mono text-xs font-semibold text-purple-600 bg-gray-50 align-top pt-4">FUNCIONA COM</td>
              <td class="px-5 py-3">
                <div class="flex flex-wrap gap-2">
                  {relationships.worksWith.map((n) => (
                    <a href={`/pt-br/arcana/${n}`} class="bg-purple-50 border border-purple-200 text-purple-700 text-xs font-medium px-2.5 py-1 rounded-lg hover:bg-purple-100 transition-colors">
                      Arcano {n}
                    </a>
                  ))}
                </div>
              </td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-5 py-3 font-mono text-xs font-semibold text-purple-600 bg-gray-50 align-top pt-4">CONFLITA COM</td>
              <td class="px-5 py-3">
                <div class="flex flex-wrap gap-2">
                  {relationships.conflictsWith.map((n) => (
                    <a href={`/pt-br/arcana/${n}`} class="bg-red-50 border border-red-200 text-red-700 text-xs font-medium px-2.5 py-1 rounded-lg hover:bg-red-100 transition-colors">
                      Arcano {n}
                    </a>
                  ))}
                </div>
              </td>
            </tr>
            <tr>
              <td class="px-5 py-3 font-mono text-xs font-semibold text-purple-600 bg-gray-50 align-top pt-4">CAUSA</td>
              <td class="px-5 py-3 text-gray-700">
                <ul class="space-y-1 list-disc list-inside">
                  {relationships.causes.map((item) => <li>{item}</li>)}
                </ul>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Perguntas Frequentes</h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <details class="group border border-gray-200 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors list-none">
              <span>{item.q}</span>
              <svg class="w-4 h-4 text-gray-400 shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-1 text-gray-600 leading-relaxed text-sm border-t border-gray-100">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="bg-gradient-to-br from-purple-50 to-purple-100 border border-purple-200 rounded-2xl p-8 text-center">
      <p class="text-sm text-purple-600 font-medium mb-2">Entenda cada arcano do seu mapa</p>
      <a href="/pt-br/" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-semibold px-6 py-3 rounded-xl text-sm transition-colors">
        Explorar todos os Arcanos
      </a>
    </div>

  </main>

  <Footer lang="pt-br" />
</Base>
