---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Compatibilidade Matriz do Destino — O que os arcanos revelam sobre seus relacionamentos';
const description = 'A compatibilidade na Matriz do Destino compara posições equivalentes de dois mapas para identificar sinergias naturais e tensões estruturais. Entenda como funciona o cálculo, o que significa conflito de arcanos e como usar isso em relacionamentos.';
const canonicalUrl = 'https://matrixdestiny.co/pt-br/compatibilidade-matriz-do-destino';

const hreflang = [
  { lang: 'pt-BR', url: 'https://matrixdestiny.co/pt-br/compatibilidade-matriz-do-destino' },
  { lang: 'uk', url: 'https://matrixdestiny.co/uk/sumysnist-matrytsia-doli' },
];

const relationships = {
  isA: 'hub de compatibilidade — página central que explica como a Matriz do Destino é usada para análise de relacionamentos e compatibilidade entre mapas',
  usedFor: [
    'entender como dois mapas de Matriz do Destino interagem',
    'identificar posições de alta sinergia e alta tensão entre parceiros',
    'analisar padrões repetitivos em relacionamentos a partir dos arcanos',
    'compreender o que significa conflito estrutural entre dois mapas',
    'usar a compatibilidade como ferramenta de diagnóstico relacional, não de previsão',
  ],
  worksWith: [2, 6, 7, 11, 14, 15],
  conflictsWith: [12, 16],
  causes: [
    'capacidade de identificar onde dois mapas se complementam e onde criam atrito',
    'clareza sobre a diferença entre incompatibilidade estrutural e conflito solucionável',
    'base para conversas mais produtivas sobre padrões relacionais',
  ],
};

const faq = [
  {
    q: 'Como a compatibilidade é calculada na Matriz do Destino?',
    a: 'A análise de compatibilidade compara as posições equivalentes de dois mapas individuais — posição A com posição A, B com B, e assim por diante. Para cada par de posições, verifica-se se os arcanos têm relação de complementaridade, neutralidade ou conflito. Arcanos que conflitam em posições equivalentes criam áreas de atrito estrutural; arcanos que se complementam criam áreas de sinergia natural. O perfil de compatibilidade do par emerge da soma dessas relações em todas as nove posições.',
  },
  {
    q: 'O que significa conflito de arcanos em compatibilidade?',
    a: 'Arcanos em conflito em posições equivalentes não significam que o relacionamento é impossível ou que as pessoas são "incompatíveis". Significa que naquela dimensão específica — seja ação, campo social ou condicionamentos — os dois padrões criam atrito. Esse atrito pode ser altamente produtivo (fricção que gera crescimento) ou desgastante (fricção que consome energia sem progresso). A diferença depende de se ambas as pessoas têm consciência do padrão e estão dispostas a trabalhar com ele.',
  },
  {
    q: 'Qual posição é mais importante para compatibilidade em relacionamentos afetivos?',
    a: 'O eixo A-B (ação e campo social) tende a ser o mais relevante para compatibilidade afetiva cotidiana. O eixo C (condicionamentos profundos) é decisivo para longo prazo — é onde padrões de apego e resposta emocional profunda estão mapeados e onde os conflitos mais difíceis de nomear ficam escondidos. A posição E (centro) indica o estado de integração mais profundo — quando ambos os centros se complementam, há uma sensação de reconhecimento mútuo que vai além da atração superficial.',
  },
  {
    q: 'Existe algum par de arcanos que indique relacionamento definitivamente incompatível?',
    a: 'Não. Nenhuma combinação de arcanos determina que um relacionamento é impossível. O que a Matriz mostra são as áreas de tensão mais prováveis e o tipo de atrito que tende a surgir. Relacionamentos com alta tensão estrutural exigem mais trabalho consciente, mas não são intrinsecamente inviáveis. O sistema não é preditivo — descreve tendências, não destinos.',
  },
  {
    q: 'Como o Arcano 6 (Os Amantes) afeta a compatibilidade?',
    a: 'O Arcano 6 em qualquer posição de compatibilidade intensifica o tema de escolha consciente e comprometimento. Quando o 6 aparece em posições equivalentes de dois mapas, o relacionamento frequentemente é marcado por dilemas de escolha — a pergunta de que tipo de relacionamento é este, e o que cada pessoa está disposta a comprometer, se torna central. O 6 em posição A de uma pessoa e C da outra pode criar uma tensão entre quem age por escolha consciente e quem age por condicionamento — uma fricção produtiva se reconhecida.',
  },
  {
    q: 'A Matriz de compatibilidade pode ser usada para relacionamentos não-afetivos?',
    a: 'Sim. A análise de compatibilidade funciona para qualquer tipo de relação onde a interação é frequente e significativa — parcerias de negócio, relações entre gestor e colaborador, vínculos familiares. Em contextos profissionais, as posições mais relevantes tendem a ser B (campo social/colaboração) e D (vetor de missão). Quando os vetores D de dois sócios conflitam profundamente, surgem divergências sobre direção e propósito que vão além de preferências pessoais.',
  },
  {
    q: 'Como usar a análise de compatibilidade sem transformá-la em julgamento?',
    a: 'O risco principal em usar compatibilidade é confirmar narrativas preexistentes — usar o mapa para justificar o que já se quer acreditar sobre um relacionamento. A análise é mais útil quando abordada com curiosidade em vez de veredito: o que esse ponto de tensão está tentando mostrar? Qual padrão meu está contribuindo para esse atrito? A Matriz descreve tensões, não culpados.',
  },
  {
    q: 'Como lidar com o bloqueio emocional que surge de conflitos estruturais na Matriz?',
    a: 'O bloqueio emocional em conflitos estruturais ocorre quando o padrão de uma pessoa ativa automaticamente o mecanismo de defesa da outra — sem que nenhuma das duas consiga identificar o gatilho real. O primeiro passo é nomear o padrão: "quando você faz X, meu padrão Y é ativado." Isso transforma o conflito sem rosto em conflito com endereço. A análise de compatibilidade funciona como mapa — identifica onde esses gatilhos têm mais probabilidade de ocorrer. Com essa informação, o casal pode desenvolver linguagem compartilhada antes que o conflito escale.',
  },
];

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
