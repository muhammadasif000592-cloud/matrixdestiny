---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const hreflang = [
  { lang: 'en', url: 'https://matrixdestiny.co/' },
  { lang: 'pt-BR', url: 'https://matrixdestiny.co/pt-br/' },
  { lang: 'uk', url: 'https://matrixdestiny.co/uk/' },
];
---

<Base
  title="Матриця Долі Калькулятор — Безкоштовна Карта"
  description="Розрахуйте безкоштовну Матрицю Долі за датою народження. Зрозумійте свої карміні патерни, архетипи, сумісність та життєве призначення з психологічною точністю."
  lang="uk"
  hreflang={hreflang}
>
  <Header lang="uk" />

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight mb-4">
      Матриця Долі — Зрозумійте Свої Патерни, а Не Лише Дату
    </h1>
    <p class="text-lg text-gray-600 mb-8 max-w-2xl">
      Введіть свою дату народження, щоб отримати безкоштовну Матрицю Долі.
      Зрозумійте свої аркани, кармічний хвіст, енергію сумісності та життєве призначення.
    </p>

    <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 mb-16 max-w-md">
      <p class="text-sm text-gray-500 mb-2">Калькулятор незабаром</p>
      <h2 class="text-xl font-semibold">Введіть свою дату народження</h2>
    </div>

    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Досліджуйте 22 Аркани</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {Array.from({ length: 22 }, (_, i) => i + 1).map((n) => (
          <a
            href={`/uk/arcana/${n}`}
            class="border border-gray-200 rounded-lg p-4 text-center hover:border-purple-400 hover:bg-purple-50 transition-colors"
          >
            <span class="text-2xl font-bold text-purple-600">{n}</span>
            <p class="text-sm text-gray-600 mt-1">Аркан {n}</p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer lang="uk" />
</Base>
