---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Сумісність Матриця Долі — Що аркани розкривають про ваші стосунки';
const description = 'Сумісність у Матриці Долі порівнює еквівалентні позиції двох карт для виявлення природної синергії та структурного тертя. Дізнайтеся, як працює розрахунок, що означає конфлікт арканів і як застосовувати це у стосунках.';
const canonicalUrl = 'https://matrixdestiny.co/uk/sumysnist-matrytsia-doli';

const hreflang = [
  { lang: 'pt-BR', url: 'https://matrixdestiny.co/pt-br/compatibilidade-matriz-do-destino' },
  { lang: 'uk', url: 'https://matrixdestiny.co/uk/sumysnist-matrytsia-doli' },
];

const relationships = {
  isA: 'хаб сумісності — центральна сторінка, що пояснює, як Матриця Долі використовується для аналізу стосунків та сумісності між картами',
  usedFor: [
    'зрозуміти, як взаємодіють дві карти Матриці Долі',
    'виявити позиції високої синергії та високого тертя між партнерами',
    'аналізувати повторювані патерни у стосунках через аркани',
    'осягнути, що означає структурний конфлікт між двома картами',
    'використовувати сумісність як інструмент діагностики стосунків, а не передбачення',
  ],
  worksWith: [2, 6, 7, 11, 14, 15],
  conflictsWith: [12, 16],
  causes: [
    'здатність визначити, де дві карти доповнюють одна одну, а де створюють тертя',
    'ясність щодо різниці між структурною несумісністю та вирішуваним конфліктом',
    'основа для більш продуктивних розмов про реляційні патерни',
  ],
};

const faq = [
  {
    q: 'Як розраховується сумісність у Матриці Долі?',
    a: "Аналіз сумісності порівнює еквівалентні позиції двох індивідуальних карт — позиція A з позицією A, B з B і так далі. Для кожної пари позицій перевіряється, чи мають аркани відносини доповнюваності, нейтральності або конфлікту. Аркани, що конфліктують в еквівалентних позиціях, створюють зони структурного тертя; аркани, що доповнюють одне одного, створюють зони природної синергії. Профіль сумісності пари виникає із суми цих відносин в усіх дев'яти позиціях.",
  },
  {
    q: 'Що означає конфлікт арканів у сумісності?',
    a: 'Аркани в конфлікті в еквівалентних позиціях не означають, що стосунки неможливі або що люди "несумісні". Це означає, що в тому конкретному вимірі — будь то дія, соціальне поле або обумовленості — два патерни створюють тертя. Це тертя може бути вкрай продуктивним (тертя, що породжує зростання) або виснажливим (тертя, що споживає енергію без прогресу). Різниця залежить від того, чи усвідомлюють обидві людини патерн і чи готові з ним працювати.',
  },
  {
    q: 'Яка позиція найважливіша для сумісності у романтичних стосунках?',
    a: 'Вісь A-B (дія та соціальне поле) зазвичай є найбільш релевантною для романтичної сумісності, оскільки саме тут відбувається більша частина щоденної взаємодії. Вісь C (глибинні обумовленості) є релевантною для довгострокової сумісності — саме там картуються патерни прив\'язаності та глибокої емоційної реакції. Позиція E (центр) кожної людини вказує на найглибший стан інтеграції — коли обидва центри доповнюють одне одного, виникає відчуття взаємного впізнавання.',
  },
  {
    q: 'Чи існує пара арканів, що вказує на абсолютну несумісність?',
    a: 'Ні. Жодна комбінація арканів не визначає, що стосунки неможливі. Матриця показує найбільш імовірні зони напруги та тип тертя, що може виникнути. Стосунки з високим структурним тертям вимагають більш свідомої роботи, але за своєю суттю не є нежиттєздатними. Система не є передбачливою — вона описує тенденції, а не долі.',
  },
  {
    q: 'Як Аркан 6 (Закохані) впливає на сумісність?',
    a: 'Аркан 6 у будь-якій позиції сумісності посилює тему свідомого вибору та зобов\'язання. Коли 6 з\'являється в еквівалентних позиціях двох карт, стосунки часто позначені дилемами вибору — питання про те, яким є цей зв\'язок і що кожна людина готова поступитися, стає центральним. 6 у позиції A однієї людини та C іншої може створити напругу між тим, хто діє через свідомий вибір, і тим, хто діє через обумовленість — продуктивне тертя якщо визнане.',
  },
  {
    q: 'Чи можна використовувати аналіз сумісності для нероматичних стосунків?',
    a: 'Так. Аналіз сумісності працює для будь-якого типу стосунків, де взаємодія є частою і значущою — ділове партнерство, відносини між керівником і співробітником, родинні зв\'язки. У професійних контекстах найбільш релевантними позиціями є зазвичай B (соціальне поле/співпраця) та D (вектор місії). Коли вектори D двох партнерів глибоко конфліктують, виникають розбіжності щодо напряму і мети, що виходять за межі особистих уподобань.',
  },
  {
    q: 'Як використовувати аналіз сумісності, не перетворюючи його на осуд?',
    a: 'Головний ризик у використанні сумісності — підтвердження вже існуючих наративів: використання карти для виправдання того, в що вже хочеться вірити про стосунки. Аналіз найкорисніший, коли до нього підходять з цікавістю, а не з вердиктом: що ця точка напруги намагається показати? Який мій патерн сприяє цьому тертю? Матриця описує напруги, а не винуватців.',
  },
];

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  inLanguage: 'uk',
  publisher: { '@type': 'Organization', name: 'Matrix Destiny', url: 'https://matrixdestiny.co' },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: 'https://matrixdestiny.co/uk/' },
    { '@type': 'ListItem', position: 2, name: 'Сумісність Матриця Долі', item: canonicalUrl },
  ],
});
---

<Base title={title} description={description} lang="uk" hreflang={hreflang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <Header lang="uk" />

  <main class="max-w-3xl mx-auto px-6 py-12">

    <nav aria-label="breadcrumb" class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/uk/" class="hover:text-purple-600 transition-colors">Головна</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-800 font-medium">Сумісність Матриця Долі</span>
    </nav>

    <header class="mb-10">
      <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
        Хаб Сумісність
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 mb-4 leading-tight">
        Сумісність Матриця Долі — Що аркани розкривають про ваші стосунки
      </h1>
      <p class="text-lg text-gray-500 leading-relaxed">{description}</p>
    </header>

    <article class="mb-14 text-gray-700 leading-relaxed space-y-5
      [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-gray-900 [&_h2]:mt-10 [&_h2]:mb-3
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-gray-900 [&_h3]:mt-6 [&_h3]:mb-2
      [&_p]:mb-0
      [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1
      [&_strong]:font-semibold [&_strong]:text-gray-900">

      <p>Сумісність у Матриці Долі — це не оцінка від 0 до 100. Немає "несумісності" в абсолютному сенсі. Аналіз сумісності створює карту ймовірних динамік між двома патернами функціонування — де вони підсилюють одне одного, де створюють тертя, і які виміри стосунків вимагатимуть свідомої роботи.</p>

      <p>Це і є справжня цінність методу для стосунків: не передбачити, чи спрацює, а точно картувати, де і чому тертя виникає коли виникає. Багато пар, які роками приписували конфлікти "несумісності характерів" або "непримиренним відмінностям", виявили в аналізі Матриці мову для встановлення того, що конфлікт концентрувався в одному-двох конкретних вимірах, а не у всьому.</p>

      <h2>Що таке сумісність у мові Матриці</h2>

      <p>Кожна карта Матриці Долі має дев'ять позицій. Аналіз сумісності між двома картами порівнює еквівалентні позиції: A з A, B з B, C з C, D з D, E з E та чотири середні точки. Для кожної пари позицій система перевіряє відносини між двома арканами.</p>

      <p>Аркани можуть мати три типи відносин між собою: доповнюваність (патерни взаємно підсилюються), нейтральність (співіснують без напруги чи особливої синергії) або конфлікт (патерни створюють структурне тертя). Профіль сумісності виникає з розподілу цих відносин у дев'яти позиціях.</p>

      <p>Пара з високою синергією в позиціях A і B, але напругою в позиціях C, добре функціонуватиме у повсякденних діях і співпраці — але зустрічатиме тертя, коли вступають у дію глибинні обумовленості кожного, що зазвичай відбувається в кризах, під дією підвищеного стресу або під час дискусій про фундаментальні цінності.</p>

      <h2>Як працює розрахунок сумісності</h2>

      <p>Перший крок — розрахувати дві індивідуальні карти. Для цього скористайтеся <a href="/uk/kalkulator-matrytsia-doli" class="text-purple-600 hover:underline">калькулятором Матриці Долі</a> для кожної дати народження. Запишіть значення кожної позиції для обох карт.</p>

      <p>Маючи два набори позицій, порівняйте позицію за позицією. <a href="/uk/arcana/6" class="text-purple-600 hover:underline">Аркан 6 (Закохані)</a> у A однієї людини та <a href="/uk/arcana/7" class="text-purple-600 hover:underline">Аркан 7 (Колісниця)</a> у A іншої створює специфічну динаміку в полюсі дії: свідомий вибір проти спрямованого імпульсу. Це не чистий конфлікт — це напруга з творчим потенціалом якщо визнана. <a href="/uk/arcana/15" class="text-purple-600 hover:underline">Аркан 15 (Диявол)</a> у C однієї та <a href="/uk/arcana/11" class="text-purple-600 hover:underline">Аркан 11 (Сила)</a> у C іншої створює іншу динаміку в глибинних обумовленостях: компульсивні патерни проти емоційної регуляції — часто джерело тертя в моменти стресу.</p>

      <h2>Чотири вектори сумісності</h2>

      <h3>Вектор дії (позиція A × позиція A)</h3>
      <p>Визначає, як два партнери взаємодіють, коли обидва перебувають у режимі ініціативи. Висока синергія тут означає, що обидва схильні діяти у взаємодоповнюючих формах. Напруга тут створює неявну конкуренцію за те, хто веде або дії яких мають пріоритет.</p>

      <h3>Соціальний вектор (позиція B × позиція B)</h3>
      <p>Визначає, як обидва функціонують разом у спільному полі — коли вони видимі для зовнішнього світу, коли разом взаємодіють з іншими людьми, або в соціальних і професійних контекстах. Синергія тут часто і є тим, що створює відчуття "природного партнерства".</p>

      <h3>Вектор обумовленості (позиція C × позиція C)</h3>
      <p>Це найглибша і часто найскладніша вісь. Коли глибинні обумовленості двох партнерів конфліктують, кризи у стосунках схильні швидко ескалувати — оскільки патерни, що активуються на цьому рівні, є найбільш примітивними й найменш усвідомленими. <a href="/uk/arcana/2" class="text-purple-600 hover:underline">Аркан 2 (Верховна Жриця)</a> у C однієї людини (обумовленість ізоляції та внутрішнього оброблення) та <a href="/uk/arcana/14" class="text-purple-600 hover:underline">Аркан 14 (Поміркованість)</a> у C іншої (обумовленість пошуку рівноваги та інтеграції) — це не обов'язково конфлікт: це може бути доповнюваність, де один забезпечує глибину, а інший — перехід.</p>

      <h3>Вектор інтеграції (позиція E × позиція E)</h3>
      <p>Центри двох карт вказують на те, що кожна людина переживає як свій стан найбільшої внутрішньої узгодженості. Коли центри доповнюють одне одного, виникає відчуття взаємного впізнавання — людина бачить в іншій щось із того, до чого сама прагне. Коли центри конфліктують, може бути тонка складність у сприйнятті іншого як "повністю інтегрованого".</p>

      <h2>Що аркани в конфлікті насправді означають</h2>

      <p>Конфлікт арканів у контексті сумісності — не вирок. <a href="/uk/arcana/13" class="text-purple-600 hover:underline">Аркан 13 (Смерть)</a> та <a href="/uk/arcana/12" class="text-purple-600 hover:underline">Аркан 12 (Повішений)</a> в еквівалентних позиціях створюють напругу між імпульсом завершувати та імпульсом зупиняти — але ця напруга може також породити пару, де один є каталізатором змін, а інший — простором для роздумів перед змінами. Питання в тому, чи визнається ця напруга і чи може вона бути названа, чи залишається конфліктом без обличчя.</p>

      <p>Найважчі конфлікти для управління в сумісності — ті, що виникають у позиціях C — оскільки вони охоплюють обумовленості, які людина часто не визнає як свої. Коли обумовленість однієї людини активує захисний патерн обумовленості іншої, конфлікт здається предметним, але насправді він стосується базового патерну. Це тип тертя, що повертається навіть після позірних вирішень.</p>

      <h2>Сумісність у довгострокових стосунках</h2>

      <p>Аналіз сумісності є більш корисним для усталених стосунків, ніж для нових. У нових стосунках недостатньо досвіду, щоб відкалібрувати, які напруги є структурними, а які — ситуативними. В усталених стосунках аналіз дозволяє назвати вже існуючі патерни — дати точну мову тому, що вже відбувається.</p>

      <p>Важлива примітка: висока сумісність у всіх осях не гарантує задовільних стосунків. Стосунки з низьким структурним тертям можуть бути комфортними, але мало стимулюючими — де жоден з партнерів не кидає виклик іншому для зростання. Певне тертя є продуктивним. Питання не в усуненні напруги, а у визначенні, які напруги є джерелами зростання, а які — просто руйнівними.</p>

      <h2>Як використовувати цей аналіз, не визначаючи майбутнє стосунків</h2>

      <p>Найпоширеніша помилка — використання аналізу сумісності як вердикту: "наші карти конфліктують у C, отже не спрацює." Карта описує тенденції функціонування, а не долі. Те, що вона пропонує — це діагностика того, де найбільш необхідна свідома робота.</p>

      <p>Продуктивний спосіб використання — як карта для дослідження: де наші патерни створюють найбільше тертя? Який конкретний тип конфлікту виникає в цій позиції? Який мій патерн сприяє цьому тертю? Ці запитання відкривають розмову; вердикт її закриває.</p>

      <p>Щоб розрахувати свою індивідуальну карту та розпочати аналіз, скористайтеся <a href="/uk/kalkulator-matrytsia-doli" class="text-purple-600 hover:underline">калькулятором Матриці Долі</a>. Щоб зрозуміти значення кожного аркану, що з'являється у ваших картах, відвідайте сторінки окремих арканів — наприклад, <a href="/uk/arcana/6" class="text-purple-600 hover:underline">Аркан 6</a>, <a href="/uk/arcana/11" class="text-purple-600 hover:underline">Аркан 11</a> або <a href="/uk/arcana/14" class="text-purple-600 hover:underline">Аркан 14</a> — щоб побачити, в якому полюсі функціонує патерн і що це означає для динаміки пари.</p>
    </article>

