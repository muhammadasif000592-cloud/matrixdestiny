---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Сумісність Матриця Долі — Що аркани розкривають про ваші стосунки';
const description = "Сумісність у Матриці Долі порівнює еквівалентні позиції двох карт для виявлення природної синергії та структурного тертя. Дізнайтеся, як працює розрахунок, що означає конфлікт арканів і як застосовувати це у стосунках.";
const canonicalUrl = 'https://matrixdestiny.co/uk/sumysnist-matrytsia-doli';

const hreflang = [
  { lang: 'pt-BR', url: 'https://matrixdestiny.co/pt-br/compatibilidade-matriz-do-destino' },
  { lang: 'uk', url: 'https://matrixdestiny.co/uk/sumysnist-matrytsia-doli' },
];

const relationships = {
  isA: "хаб сумісності — центральна сторінка, що пояснює, як Матриця Долі використовується для аналізу стосунків та сумісності між картами",
  usedFor: [
    "зрозуміти, як взаємодіють дві карти Матриці Долі",
    "виявити позиції високої синергії та високого тертя між партнерами",
    "аналізувати повторювані патерни у стосунках через аркани",
    "осягнути, що означає структурний конфлікт між двома картами",
    "використовувати сумісність як інструмент діагностики стосунків, а не передбачення",
  ],
  worksWith: [2, 6, 7, 11, 14, 15],
  conflictsWith: [12, 16],
  causes: [
    "здатність визначити, де дві карти доповнюють одна одну, а де створюють тертя",
    "ясність щодо різниці між структурною несумісністю та вирішуваним конфліктом",
    "основа для більш продуктивних розмов про реляційні патерни",
  ],
};

const faq = [
  {
    q: "Як розраховується сумісність у Матриці Долі?",
    a: "Аналіз сумісності порівнює еквівалентні позиції двох індивідуальних карт — позиція A з позицією A, B з B і так далі. Для кожної пари позицій перевіряється, чи мають аркани відносини доповнюваності, нейтральності або конфлікту. Аркани, що конфліктують в еквівалентних позиціях, створюють зони структурного тертя; аркани, що доповнюють одне одного — зони природної синергії. Профіль сумісності виникає із суми цих відносин в усіх дев'яти позиціях.",
  },
  {
    q: "Що означає конфлікт арканів у сумісності?",
    a: "Аркани в конфлікті в еквівалентних позиціях не означають, що стосунки неможливі. Це означає, що в тому конкретному вимірі два патерни створюють тертя. Тертя може бути продуктивним (стимулює зростання) або виснажливим (споживає енергію без прогресу). Різниця залежить від того, чи усвідомлюють обидві людини патерн і чи готові з ним працювати.",
  },
  {
    q: "Яка позиція найважливіша для сумісності у романтичних стосунках?",
    a: "Вісь A-B (дія та соціальне поле) найбільш релевантна для щоденної романтичної взаємодії. Вісь C (глибинні обумовленості) вирішальна для довгострокової сумісності — там картуються патерни прив'язаності та глибокої емоційної реакції. Позиція E (центр) вказує на стан найглибшої інтеграції — коли обидва центри доповнюють одне одного, виникає відчуття взаємного впізнавання.",
  },
  {
    q: "Чи існує пара арканів, що вказує на абсолютну несумісність?",
    a: "Ні. Жодна комбінація арканів не визначає, що стосунки неможливі. Матриця показує найбільш імовірні зони напруги та тип тертя, що може виникнути. Стосунки з високим структурним тертям вимагають більш свідомої роботи, але не є нежиттєздатними за своєю суттю. Система описує тенденції, а не долі.",
  },
  {
    q: "Як Аркан 6 (Закохані) впливає на сумісність?",
    a: "Аркан 6 у будь-якій позиції сумісності посилює тему свідомого вибору та зобов'язання. Коли 6 з'являється в еквівалентних позиціях двох карт, стосунки часто позначені дилемами вибору. 6 у позиції A однієї людини та C іншої може створити напругу між тим, хто діє через свідомий вибір, і тим, хто діє через обумовленість — продуктивне тертя якщо визнане.",
  },
  {
    q: "Чи можна використовувати аналіз сумісності для нероматичних стосунків?",
    a: "Так. Аналіз сумісності працює для будь-якого типу стосунків — ділове партнерство, відносини між керівником і співробітником, родинні зв'язки. У професійних контекстах найбільш релевантними є позиції B (соціальне поле/співпраця) та D (вектор місії). Коли вектори D двох партнерів глибоко конфліктують, виникають розбіжності щодо напряму і мети.",
  },
  {
    q: "Як використовувати аналіз сумісності, не перетворюючи його на осуд?",
    a: "Головний ризик — підтвердження вже існуючих наративів: використання карти для виправдання того, в що вже хочеться вірити про стосунки. Аналіз найкорисніший, коли до нього підходять з цікавістю, а не з вердиктом: що ця точка напруги намагається показати? Який мій патерн сприяє цьому тертю? Матриця описує напруги, а не винуватців.",
  },
  {
    q: "Як впоратися з емоційним блокуванням, що виникає через структурні конфлікти в Матриці?",
    a: "Емоційний блок у структурних конфліктах виникає, коли патерн однієї людини автоматично активує захисний механізм іншої — без можливості визначити реальний тригер. Перший крок — назвати патерн: «коли ти робиш X, мій патерн Y активується». Це перетворює конфлікт без обличчя на конфлікт з адресою. Аналіз сумісності функціонує як карта — визначає, де ці тригери найімовірніші. З цією інформацією пара може виробити спільну мову до того, як конфлікт ескалує.",
  },
];

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  inLanguage: 'uk',
  publisher: { '@type': 'Organization', name: 'Matrix Destiny', url: 'https://matrixdestiny.co' },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: 'https://matrixdestiny.co/uk/' },
    { '@type': 'ListItem', position: 2, name: 'Сумісність Матриця Долі', item: canonicalUrl },
  ],
});
---

<Base title={title} description={description} lang="uk" hreflang={hreflang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <Header lang="uk" />

  <main class="max-w-3xl mx-auto px-6 py-12">

    <nav aria-label="breadcrumb" class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/uk/" class="hover:text-purple-600 transition-colors">Головна</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-800 font-medium">Сумісність Матриця Долі</span>
    </nav>

    <header class="mb-10">
      <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
        Хаб Сумісність
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 mb-4 leading-tight">
        Сумісність Матриця Долі — Що аркани розкривають про ваші стосунки
      </h1>
      <div class="mt-5 mb-4 space-y-1.5 text-base text-gray-600 italic leading-relaxed">
        <p>Ви відчуваєте, що одні й ті самі конфлікти у стосунках повторюються, незалежно від партнера?</p>
        <p>Що певні емоційні блоки повертаються щоразу, коли стосунки поглиблюються?</p>
        <p>Що щось у патерні іншої людини викликає у вас реакцію, яку ви самі не можете пояснити?</p>
      </div>
      <p class="text-lg text-gray-500 leading-relaxed">{description}</p>
    </header>

    <!-- Quick-answer block -->
    <div class="mb-8 border-l-4 border-purple-500 bg-purple-50 rounded-r-xl overflow-hidden">
      <div class="px-5 py-3 border-b border-purple-100">
        <p class="text-xs font-semibold text-purple-700 uppercase tracking-wider">Швидкі відповіді</p>
      </div>
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-b border-purple-100">
            <td class="px-5 py-2.5 font-medium text-gray-800 w-2/5 align-top">Що це?</td>
            <td class="px-5 py-2.5 text-gray-700">Порівняльний аналіз двох карт Матриці Долі в 9 еквівалентних позиціях</td>
          </tr>
          <tr class="border-b border-purple-100 bg-white/50">
            <td class="px-5 py-2.5 font-medium text-gray-800 align-top">Як працює?</td>
            <td class="px-5 py-2.5 text-gray-700">Порівнює аркани в еквівалентних позиціях: синергія, нейтральність або конфлікт по кожній осі</td>
          </tr>
          <tr class="border-b border-purple-100">
            <td class="px-5 py-2.5 font-medium text-gray-800 align-top">Що розкриває?</td>
            <td class="px-5 py-2.5 text-gray-700">Де патерни підсилюють одне одного, де створюють структурне тертя, що потребує свідомої роботи</td>
          </tr>
          <tr class="border-b border-purple-100 bg-white/50">
            <td class="px-5 py-2.5 font-medium text-gray-800 align-top">Найкращі комбінації?</td>
            <td class="px-5 py-2.5 text-gray-700">Аркани 6+2, 14+2, 21+1 у позиціях B та C — висока синергія у соціальному полі та обумовленостях</td>
          </tr>
          <tr class="border-b border-purple-100">
            <td class="px-5 py-2.5 font-medium text-gray-800 align-top">Найважчі комбінації?</td>
            <td class="px-5 py-2.5 text-gray-700">Аркани 15+11, 13+12, 16+7 в еквівалентних позиціях — високий структурний конфлікт</td>
          </tr>
          <tr>
            <td class="px-5 py-2.5 font-medium text-gray-800 align-top">Як покращити важку комбінацію?</td>
            <td class="px-5 py-2.5 text-gray-700">Назвати конкретну напругу кожної позиції, визначити патерн кожного, працювати усвідомлено</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Compatibility calculator placeholder -->
    <div id="kalkuliator-sumisnosti" class="mb-10 p-6 border-2 border-dashed border-purple-200 rounded-2xl bg-purple-50 text-center">
      <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 text-xs font-semibold px-3 py-1 rounded-full mb-3 uppercase tracking-wider">
        Незабаром
      </div>
      <p class="text-gray-800 font-semibold mb-2">Калькулятор сумісності Матриці Долі</p>
      <p class="text-gray-600 text-sm mb-4">Калькулятор сумісності дозволить порівнювати дві карти автоматично. Поки що розрахуйте кожну карту окремо і порівняйте позицію за позицією.</p>
      <a href="/uk/kalkulator-matrytsia-doli" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors">
        Розрахувати мою карту →
      </a>
    </div>

    <article class="mb-14 text-gray-700 leading-relaxed space-y-5
      [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-gray-900 [&_h2]:mt-10 [&_h2]:mb-3
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-gray-900 [&_h3]:mt-6 [&_h3]:mb-2
      [&_p]:mb-0
      [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1
      [&_strong]:font-semibold [&_strong]:text-gray-900">

      <p>Сумісність у Матриці Долі — не оцінка від 0 до 100. Немає "несумісності" у абсолютному сенсі. Аналіз виявляє карту ймовірних динамік між двома патернами — де вони підсилюють одне одного, де створюють тертя, і які виміри стосунків потребуватимуть свідомої роботи.</p>

      <p>Реальна цінність методу: не передбачити, чи спрацює, а точно картувати, де і чому тертя виникає коли виникає. Пари, що роками приписували конфлікти "несумісності характерів", знаходили в аналізі Матриці мову для встановлення того, що конфлікт концентрувався в одному-двох конкретних вимірах. Щоб зрозуміти метод загалом, перегляньте <a href="/uk/shcho-take-matrytsia-doli" class="text-purple-600 hover:underline">що таке Матриця Долі</a>.</p>

      <blockquote class="my-6 pl-5 border-l-4 border-purple-400 text-lg text-purple-700 italic leading-relaxed">
        "Конфлікт не був скрізь — він концентрувався в одному-двох вимірах. Назвати це з точністю — ось що робить роботу можливою."
      </blockquote>

      <h2>Що таке сумісність у мові Матриці</h2>

      <p>Кожна карта Матриці Долі має дев'ять позицій. Аналіз сумісності порівнює еквівалентні позиції: A з A, B з B, C з C, D з D, E з E та чотири середні точки. Для кожної пари позицій система перевіряє відносини між двома арканами.</p>

      <p>Три типи відносин між арканами: доповнюваність (патерни взаємно підсилюються), нейтральність (співіснують без напруги чи синергії), конфлікт (патерни створюють структурне тертя). Профіль сумісності виникає з розподілу цих відносин у дев'яти позиціях.</p>

      <p>Пара з високою синергією в A і B, але напругою в C — добре функціонуватиме у повсякденній взаємодії, але зустрічатиме тертя, коли вступають у дію глибинні обумовленості. Це відбувається в кризах, при підвищеному стресі або під час дискусій про фундаментальні цінності.</p>

      <h2>Як працює розрахунок сумісності</h2>

      <p>Перший крок — розрахувати дві індивідуальні карти через <a href="/uk/kalkulator-matrytsia-doli" class="text-purple-600 hover:underline">калькулятор Матриці Долі</a> для кожної дати народження. Запишіть значення кожної позиції для обох карт.</p>

      <p>Маючи два набори позицій, порівняйте позицію за позицією. <a href="/uk/arcana/6" class="text-purple-600 hover:underline">Аркан 6 (Закохані)</a> у A однієї людини та <a href="/uk/arcana/7" class="text-purple-600 hover:underline">Аркан 7 (Колісниця)</a> у A іншої — свідомий вибір проти спрямованого імпульсу. Не чистий конфлікт — напруга з творчим потенціалом якщо визнана. <a href="/uk/arcana/15" class="text-purple-600 hover:underline">Аркан 15 (Диявол)</a> у C однієї та <a href="/uk/arcana/11" class="text-purple-600 hover:underline">Аркан 11 (Сила)</a> у C іншої — компульсивні патерни проти емоційної регуляції. Часто джерело тертя в моменти стресу.</p>

      <blockquote class="my-6 pl-5 border-l-4 border-purple-400 text-lg text-purple-700 italic leading-relaxed">
        "Аналіз не запитує, чи спрацює — він визначає, де концентрується структурне тертя і яка свідома робота це вимагає."
      </blockquote>

      <h2>Чотири вектори сумісності</h2>

      <h3>Вектор дії (позиція A × позиція A)</h3>
      <p>Визначає взаємодію, коли обидва партнери у режимі ініціативи. Висока синергія — дії доповнюють одна одну природно. Напруга тут — неявна конкуренція за те, хто веде або дії яких мають пріоритет.</p>

      <h3>Соціальний вектор (позиція B × позиція B)</h3>
      <p>Визначає функціонування разом у спільному полі — у взаємодії з зовнішнім світом, у соціальних та професійних контекстах. Синергія тут — те, що створює відчуття "природного партнерства".</p>

      <h3>Вектор обумовленості (позиція C × позиція C)</h3>
      <p>Найглибша і часто найскладніша вісь. Коли глибинні обумовленості конфліктують, кризи ескалують швидко — патерни цього рівня найбільш примітивні й найменш усвідомлені. <a href="/uk/arcana/2" class="text-purple-600 hover:underline">Аркан 2 (Верховна Жриця)</a> у C однієї (ізоляція та внутрішнє оброблення) та <a href="/uk/arcana/14" class="text-purple-600 hover:underline">Аркан 14 (Поміркованість)</a> у C іншої (пошук рівноваги та інтеграції) — не обов'язково конфлікт. Може бути доповнюваність: один забезпечує глибину, інший — перехід.</p>

      <h3>Вектор інтеграції (позиція E × позиція E)</h3>
      <p>Центри двох карт — стан найбільшої внутрішньої узгодженості кожної людини. Коли центри доповнюють одне одного, виникає відчуття взаємного впізнавання. Коли конфліктують — тонка складність у сприйнятті іншого як "повністю інтегрованого".</p>

      <h2>Комбінації арканів: висока гармонія і високий конфлікт</h2>

      <div class="my-6 border border-gray-200 rounded-xl overflow-hidden not-prose">
        <div class="grid grid-cols-2 divide-x divide-gray-200">
          <div class="p-4">
            <p class="text-xs font-semibold text-green-600 uppercase tracking-wider mb-3">Висока гармонія</p>
            <div class="space-y-2 text-sm text-gray-700">
              <div><strong class="text-gray-900">6 + 2</strong> — свідомий вибір + внутрішнє оброблення; рішення з глибиною</div>
              <div><strong class="text-gray-900">14 + 2</strong> — інтеграція + тиша; спільний ритм без потреби пояснювати</div>
              <div><strong class="text-gray-900">21 + 1</strong> — завершення + ініціатива; один завершує те, що інший починає</div>
              <div><strong class="text-gray-900">10 + 3</strong> — цикли + вираз; творчість із природним ритмом змін</div>
              <div><strong class="text-gray-900">7 + 6</strong> — напрям + вибір; один веде, інший підтверджує — плавна співпраця</div>
            </div>
          </div>
          <div class="p-4">
            <p class="text-xs font-semibold text-red-600 uppercase tracking-wider mb-3">Високий структурний конфлікт</p>
            <div class="space-y-2 text-sm text-gray-700">
              <div><strong class="text-gray-900">15 + 11</strong> — компульсія + регуляція; один підсилює те, що інший намагається стримати</div>
              <div><strong class="text-gray-900">13 + 12</strong> — завершення + призупинення; імпульс завершити проти імпульсу чекати</div>
              <div><strong class="text-gray-900">16 + 7</strong> — руйнування + контроль; колапс проти жорсткості — цикли інтенсивних криз</div>
              <div><strong class="text-gray-900">18 + 4</strong> — страх + структура; структура 4 пригнічує рух 18</div>
              <div><strong class="text-gray-900">8 + 12</strong> — судження + призупинення; вердикт проти невизначеності — паралич рішень</div>
            </div>
          </div>
        </div>
      </div>

      <h2>Що аркани в конфлікті насправді означають</h2>

      <p>Конфлікт арканів у контексті сумісності — не вирок. <a href="/uk/arcana/13" class="text-purple-600 hover:underline">Аркан 13 (Смерть)</a> та <a href="/uk/arcana/12" class="text-purple-600 hover:underline">Аркан 12 (Повішений)</a> в еквівалентних позиціях — напруга між імпульсом завершувати та імпульсом зупиняти. Але ця напруга може породити пару, де один є каталізатором змін, а інший — простором для роздумів перед змінами.</p>

      <p>Найважчі конфлікти для управління — ті в позиціях C, оскільки вони охоплюють кармічні стосунки та обумовленості, які людина часто не визнає як свої. Коли обумовленість однієї активує захисний патерн іншої, конфлікт здається предметним — але насправді стосується базового патерну. Тип тертя, що повертається навіть після позірних вирішень.</p>

      <blockquote class="my-6 pl-5 border-l-4 border-purple-400 text-lg text-purple-700 italic leading-relaxed">
        "Конфлікт здається про поверхневий предмет — але стосується базового патерну. Саме тому він повертається навіть після позірних вирішень."
      </blockquote>

      <h2>Сумісність у довгострокових стосунках</h2>

      <p>Аналіз сумісності більш корисний для усталених стосунків, ніж для нових. У нових — недостатньо досвіду для калібрування, які напруги структурні, а які ситуативні. В усталених — аналіз дозволяє назвати вже існуючі патерни і дати точну мову тому, що вже відбувається.</p>

      <p>Важлива примітка: висока сумісність у всіх осях не гарантує задовільних стосунків. Стосунки з низьким структурним тертям можуть бути комфортними, але мало стимулюючими. Певне тертя продуктивне. Питання не в усуненні напруги, а у визначенні, які напруги є джерелами зростання, а які просто руйнівними.</p>

      <h2>Як використовувати цей аналіз, не визначаючи майбутнє стосунків</h2>

      <p>Найпоширеніша помилка — використання аналізу як вердикту: "наші карти конфліктують у C, отже не спрацює." Карта описує тенденції, не долі. Що вона пропонує — діагностика того, де найбільш необхідна свідома робота.</p>

      <p>Продуктивний спосіб: де наші патерни створюють найбільше тертя? Який конкретний тип конфлікту виникає в цій позиції? Що мій патерн привносить у це тертя? Ці запитання відкривають розмову; вердикт її закриває.</p>

      <p>Для розрахунку індивідуальної карти та початку аналізу скористайтеся <a href="/uk/kalkulator-matrytsia-doli" class="text-purple-600 hover:underline">калькулятором Матриці Долі</a>. Для розуміння значення кожного аркану відвідайте сторінки окремих арканів — наприклад, <a href="/uk/arcana/6" class="text-purple-600 hover:underline">Аркан 6</a>, <a href="/uk/arcana/11" class="text-purple-600 hover:underline">Аркан 11</a> або <a href="/uk/arcana/14" class="text-purple-600 hover:underline">Аркан 14</a>.</p>
    </article>

